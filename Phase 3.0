pygame.display.flip()
running = True
while running:
    #TIMERS STUFF
    clock.tick(SPEED)
    x = 0
    y = 0
    for event in pygame.event.get():
        #redundant quit program
        if event.type == pygame.QUIT:
            running = False
        if event.type == pygame.MOUSEBUTTONDOWN:
            pos = event.pos
            x = pos[0]
            y = pos[1]
    
    #long if loops to find which box was clicked...

    if (cx<x) and (x<cx*5):
        track.game_map(track.locs,track.locs_length) # all primitive maps need track.locs already defined
        for i in range(4):
            if (cy*(i+4)<y) and (y<cy*(i+5)):
                if i == 0:
                    print("you clicked pbox1!")
                    track.game_map(track.locs,track.locs_length)
                    running = False
                elif i == 1:
                    print("you clicked pbox2!")
                    running = False
                elif i == 2:
                    print("you clicked pbox3!")
                    running = False
                elif i == 3:
                    print("you clicked pbox4!")
                    running = False
    elif (cx<x*6) and (x<cx*10):
        for i in range(4):
            # all advanced maps create their own track.locs
            if (cy*(i+4)<y) and (y<cy*(i+5)):
                if i == 0:
                    track.game_map_a(track.locs,track.locs_length)
                    print("you clicked abox1!")
                    running = False
                elif i == 1:
                    print("you clicked abox2!")
                    running = False
                elif i == 2:
                    print("you clicked abox3!")
                    running = False
                elif i == 3:
                    print("you clicked abox4!")
                    running = False







        

"""
MAIN GAME LOOP --------------------------------------------------------------------------------------------------
"""

track.direction = track.starting_direction
running = True

while running:
    
    #TIMERS STUFF
    clock.tick(SPEED)
    seconds = (pygame.time.get_ticks() - start_ticks) // 1000


    screen.fill((0, 0, 0))
    
    #Events
    for event in pygame.event.get():
        #redundant quit program
        if event.type == pygame.QUIT:
            running = False

        #MOVEMENT
        keys = pygame.key.get_pressed()
    
    #centers car
    if keys[pygame.K_SPACE]:
        track.mapx = WIDTH/2
        track.mapy = HEIGHT/2
        track.direction = track.starting_direction
        track.speed = 0

    #changes direction
    if keys[pygame.K_LEFT]:
        #GOAL: car will travel in a circle if holding left
        track.direction = (track.direction - track.turn_radius) % 360

    if keys[pygame.K_RIGHT]:
        #GOAL: car will travel in a circle if holding right
        track.direction = (track.direction + track.turn_radius) % 360


    #changes speed
    track.acc = 1 - (abs(track.speed)/track.maxspeed)

    if keys[pygame.K_UP]:
        track.speed -= track.minacc * track.acc
    if keys[pygame.K_DOWN]:
        track.speed += track.minacc * track.acc

    #friction
    if track.speed > 0:
        if track.speed - track.friction > 0:
            track.speed = track.speed - track.friction
        else:
            track.speed = 0
    elif track.speed < 0:
        if track.speed - track.friction < 0:
            track.speed = track.speed + track.friction
        else:
            track.speed = 0
    
    #converts direction to radians for operations
    

    #moves car
    rad = math.radians(track.direction)

    track.mapx += track.speed * (math.cos(rad))
    track.mapy += track.speed * (math.sin(rad))
    

    
    #TRACK


    #position:
    for i in range(track.locs_length):
        adjusted_loc = (track.locs[i][0] - COLS//2)*SQUARE_SIZE + WIDTH/2, (track.locs[i][1] - COLS//2)*SQUARE_SIZE + HEIGHT/2
        track.locate_point(adjusted_loc[0],adjusted_loc[1], track.mapx, track.mapy, rad, "red")
    track.laser(rad)
    pygame.draw.circle(screen, "white", (WIDTH/2, HEIGHT/2), car.size)
    
    pygame.display.flip()
